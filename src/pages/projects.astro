---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
---

<BaseLayout title="Projects | Jonathan Diaz" sideBarActiveItemID="projects">
  <div class="mb-10">
    <h1 class="text-4xl font-bold mb-2">Projects</h1>
    <p class="text-lg text-base-content/80">Technical work spanning tracking, sensor fusion, computer vision, and applied AI.</p>
  </div>

  <div class="space-y-8">
    <div id="imu-orientation">
      <ProjectCard
        title="IMU Orientation Tracking on Raspberry Pi"
        summary="Built a beginner sensor fusion pipeline for orientation tracking using IMU data and filtering methods."
        stack={["Python", "Raspberry Pi", "IMU", "Kalman Filter"]}
        problem="Need to estimate device orientation from noisy IMU readings for tracking and robotics applications."
        implementation="Designed and implemented orientation tracking pipeline with complementary/ Kalman filtering, data processing, and visualization."
      />
    </div>

    <div id="golf-tracking">
      <ProjectCard
        title="Golf Ball Tracking and Launch Estimation"
        summary="Video-based ball detection and trajectory estimation using computer vision and nonlinear filtering."
        stack={["Computer Vision", "UKF/EKF", "Python"]}
        problem="Estimate launch conditions and trajectory from video of golf ball flight for analysis and training."
        implementation="Developed detection pipeline, tracking logic, and extended/unscented Kalman filter for state estimation from video."
      />
    </div>

    <div id="horizon-hud">
      <ProjectCard
        title="HORIZON Vehicular AI HUD Platform"
        summary="Developing a modular Raspberry Pi-based vehicular HUD platform combining driving analytics, sensor inputs, environmental monitoring, and visualization."
        stack={["Raspberry Pi", "Python", "Sensor Fusion"]}
        problem="Bring heads-up display and situational awareness to everyday driving with modular, affordable hardware."
        implementation="Ongoing development of sensor integration, data fusion, and display pipeline."
        badge="In Progress"
      />
    </div>
  </div>
</BaseLayout>
