---
import { Github } from '@lucide/astro';

interface Props {
  title: string;
  summary: string;
  stack: string[];
  problem?: string;
  implementation?: string;
  githubUrl?: string;
  projectUrl?: string;
  image?: string;
  badge?: string;
}

const { title, summary, stack, problem, implementation, githubUrl, projectUrl, image = "/post_img.webp", badge } = Astro.props;
const primaryUrl = projectUrl || githubUrl || "#";
const hasLink = primaryUrl && primaryUrl !== "#";
---

<div class="card bg-base-200 shadow-md hover:shadow-xl hover:-translate-y-1 transition duration-300 overflow-hidden">
  <figure class="relative">
    {image && (
      <img
        src={image}
        alt={title}
        class="w-full h-40 object-cover"
      />
    )}
    {badge && (
      <span class="badge badge-secondary absolute top-2 right-2">{badge}</span>
    )}
  </figure>
  <div class="card-body">
    <h2 class="card-title text-xl">
      {title}
    </h2>
    <p class="text-base-content/80">{summary}</p>
    {problem && (
      <p class="text-sm text-base-content/70"><span class="font-medium">Problem:</span> {problem}</p>
    )}
    {implementation && (
      <p class="text-sm text-base-content/70"><span class="font-medium">My role:</span> {implementation}</p>
    )}
    <div class="flex flex-wrap gap-2 mt-2">
      {stack.map((tech) => (
        <span class="badge badge-outline badge-sm">{tech}</span>
      ))}
    </div>
    <div class="card-actions justify-end mt-4">
      {githubUrl && (
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-ghost btn-sm gap-1">
          <Github class="w-4 h-4" />
          GitHub
        </a>
      )}
      {projectUrl && projectUrl !== "#" && (
        <a href={projectUrl} class="btn btn-primary btn-sm">View Project</a>
      )}
    </div>
  </div>
</div>
